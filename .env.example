# 飞书应用配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# 硅基流动API
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 数据库
DB_HOST=postgres
DB_PORT=5432
DB_NAME=feishu_bot
DB_USER=postgres
DB_PASSWORD=change_this_strong_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 功能开关
ENABLE_AI_PARSING=true
ENABLE_AUTO_REMINDER=true
ENABLE_RISK_WARNING=true
